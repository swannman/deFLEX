[Unit]
Description=FLEX pager message tail web viewer (logs -> WebSocket feed)
After=network-online.target flex-receiver.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/gridstream-waterfall-venv/bin/uvicorn flex_tail_server:app --host 0.0.0.0 --port 8091 --log-level warning
WorkingDirectory=/usr/local/bin
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
